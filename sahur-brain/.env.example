# ---- Device control ----
# iPhone build ONLY: device control server on the device (wifi IP, or 127.0.0.1 over
# iproxy). The Mac build (sahur_mac.py / ./scripts/run-mac.sh) needs NOTHING here —
# it controls the Mac with AppleScript, no server, no URL, no extra config.
DEVICE_BASE_URL=http://192.168.1.87:8090

# ---- MiniMax (LLM brain + cloned TTS voice) ----
MINIMAX_API_KEY=sk-...
# OpenAI-compatible chat endpoint. International: https://api.minimax.io/v1
MINIMAX_BASE_URL=https://api.minimax.io/v1
MINIMAX_MODEL=MiniMax-Text-01
# Needed only by voiceclone.py file upload:
MINIMAX_GROUP_ID=
# TTS model + cloned voice id (from voiceclone.py). Leave SAHUR_VOICE_ID blank to use a stock voice.
MINIMAX_TTS_MODEL=speech-02-turbo
SAHUR_VOICE_ID=

# Per-persona cloned voice ids (from voiceclone.py). Leave blank to fall back to a stock voice.
# These are intentionally NOT hardcoded in source — set your own here.
BIBI_VOICE_ID=
TRUMP_VOICE_ID=
CHARLIE_VOICE_ID=
OBAMA_VOICE_ID=
BIDEN_VOICE_ID=
MRBEAST_VOICE_ID=
# Obama/Biden/MrBeast clones can live on a second MiniMax account:
OBAMA_MINIMAX_API_KEY=

# ---- Moss (UI grounding index) ----
MOSS_PROJECT_ID=
MOSS_PROJECT_KEY=
MOSS_UI_INDEX=sahur-ui
MOSS_MODEL_ID=moss-minilm

# ---- Brain (planner/orchestrator/flavor) ----
# Claude via Anthropic — primary brain.
ANTHROPIC_API_KEY=sk-ant-...
# SAHUR_BRAIN_MODEL=claude-sonnet-4-6

# ---- Deepgram (STT) ----
DEEPGRAM_API_KEY=...
DEEPGRAM_MODEL=nova-2

# ---- LiveKit Cloud (Phase 2/3) ----
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=API...
LIVEKIT_API_SECRET=...
TOKEN_PORT=8788
